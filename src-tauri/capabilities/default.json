{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions for the Odyssey app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope",
    "dialog:default",
    "shell:default",
    "shell:allow-open"
  ]
}
