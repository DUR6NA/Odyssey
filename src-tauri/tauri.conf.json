{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Odyssey",
  "version": "0.6.0-beta.1",
  "identifier": "com.dur6na.odyssey",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{
      "title": "Odyssey",
      "width": 1400,
      "height": 900,
      "minWidth": 900,
      "minHeight": 600,
      "resizable": true,
      "maximized": true,
      "fullscreen": false,
      "visible": false,
      "decorations": false,
      "transparent": false,
      "url": "Welcome.html",
      "devtools": true
    }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© Dur6na 2025"
  }
}
